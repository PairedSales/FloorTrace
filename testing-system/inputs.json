{
  "comment": "Comprehensive Wall Detection Test Configuration",
  "version": "1.0",
  
  "inputImage": "../ExampleFloorplan.png",
  
  "preprocessing": {
    "thresholdMethod": "adaptive",
    "globalThresholdValue": 128,
    "adaptiveWindowSize": 15,
    "adaptiveC": 2,
    "removeNoise": true,
    "minComponentSize": 15,
    "useClosing": true,
    "closingKernelSize": 9
  },
  
  "wallDetection": {
    "minWallLength": 50,
    "fillGaps": true,
    "maxGapLength": 100,
    "debugMode": true
  },
  
  "lineDetection": {
    "minLength": 50,
    "minScore": 0.2,
    "maxGap": 10,
    "orientationConstraint": false,
    "angleTolerance": 0.785398,
    "edgeThresholdPercent": 5,
    "minEdgeThreshold": 0.1,
    "minChainLength": 3
  },
  
  "segmentMerging": {
    "maxDistance": 20,
    "maxGap": 50,
    "angleTolerance": 0.2
  },
  
  "gapFilling": {
    "maxGapLength": 100,
    "alignmentTolerance": 10,
    "angleTolerance": 0.1
  },
  
  "postProcessing": {
    "minLength": 50,
    "enforceOrientation": false,
    "allowedOrientations": ["horizontal", "vertical", "diagonal"],
    "angleTolerance": 0.785398,
    "removeIsolated": false,
    "connectionThreshold": 25,
    "snapGrid": false,
    "gridSize": 5,
    "snapOrientation": false,
    "removeDups": true,
    "duplicateThreshold": 10,
    "applyConstraints": false,
    "classifyExterior": true,
    "edgeThreshold": null
  },
  
  "thickWallDetection": {
    "enabled": false,
    "minWallLength": 50,
    "minThickness": 2,
    "maxThickness": 30,
    "minAspectRatio": 3,
    "maxParallelSeparation": 30
  },
  
  "topologyAnalysis": {
    "enabled": false,
    "cannyLow": 50,
    "cannyHigh": 150,
    "houghThreshold": 50,
    "minLineLength": 30,
    "maxLineGap": 10,
    "minSegmentLength": 15,
    "endpointTolerance": 8,
    "parallelTolerance": 5,
    "angleTolerance": 5,
    "gapTolerance": 8,
    "mergeCollinear": true,
    "snapEndpoints": true,
    "minWallLength": 25,
    "minConfidence": 0.3,
    "filterIsolated": false,
    "computeThickness": true,
    "mergeParallel": true
  }
}
